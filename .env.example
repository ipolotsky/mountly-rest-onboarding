# Compose-level variables. Copy to `.env` (local: defaults are fine; server: set real values).
# Per-service runtime secrets live in .envs/.production/{.app,.postgres} — see .envs.production.example/.

COMPOSE_PROJECT_NAME=onboarding

# Local passthrough so the app container can reach Claude during `make up`.
ANTHROPIC_API_KEY=

# Production only (read by docker-compose.production.yml for traefik):
DOMAIN=yourdomain.com
ACME_EMAIL=admin@yourdomain.com
