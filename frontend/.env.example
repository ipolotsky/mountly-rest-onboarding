# Frontend build/runtime vars. Copy to .env.local for local dev outside docker.
# In docker-compose.local.yml this is injected as http://localhost:8000.
VITE_API_BASE=http://localhost:8000

# Optional. When set, analytics events are also forwarded to Amplitude (lazy-loaded).
# Leave empty to keep analytics a pure no-op forward (events still POST to /api/events).
VITE_AMPLITUDE_API_KEY=
